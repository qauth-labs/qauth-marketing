{
  "name": "qauth-landing",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/qauth-landing/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "dev": {
      "executor": "@nx/vite:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "qauth-landing:build",
        "port": 3000
      },
      "configurations": {
        "development": {
          "buildTarget": "qauth-landing:build:development"
        },
        "production": {
          "buildTarget": "qauth-landing:build:production"
        }
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/qauth-landing"],
      "defaultConfiguration": "production",
      "options": {
        "command": "bun x vite build",
        "cwd": "apps/qauth-landing"
      },
      "configurations": {
        "development": {
          "args": "--mode development"
        },
        "production": {
          "args": "--mode production"
        }
      }
    },
    "preview": {
      "executor": "@nx/vite:preview-server",
      "defaultConfiguration": "production",
      "options": {
        "buildTarget": "qauth-landing:build:production"
      },
      "configurations": {
        "development": {
          "buildTarget": "qauth-landing:build:development"
        },
        "production": {
          "buildTarget": "qauth-landing:build:production"
        }
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check ."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run"
      }
    }
  }
}
